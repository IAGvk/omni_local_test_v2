# Omni v2 — Environment Variables
# Copy to .env and adjust for your machine.
# All variables are prefixed with OMNI_.

# ─── Device Profile ────────────────────────────────────────────────────────────
# mac_mps   → Apple Silicon (float16, sdpa attention)
# cuda_prod → NVIDIA GPU    (bfloat16, flash_attention_2)
# cpu       → fallback / CI
OMNI_PROFILE=mac_mps

# ─── Model Weights Path ────────────────────────────────────────────────────────
# OMNI_MODELS_DIR  : directory that contains model subfolders (default: v2/models/)
# OMNI_MODEL_SUBDIR: subfolder name inside OMNI_MODELS_DIR (auto-selected if unset)
#
# Examples:
#   OMNI_MODELS_DIR=/Volumes/ExternalSSD/models
#   OMNI_MODEL_SUBDIR=Qwen2.5-Omni-7B
# OMNI_MODELS_DIR=./models
# OMNI_MODEL_SUBDIR=Qwen2.5-Omni-3B

# ─── Generation ────────────────────────────────────────────────────────────────
# OMNI_THINKER_MAX_NEW_TOKENS=512
# OMNI_SPEAKER=Ethan         # Ethan or Chelsie
# OMNI_RETURN_AUDIO=true

# ─── System Prompt ─────────────────────────────────────────────────────────────
# Override to customise the persona (keep the "virtual human" wording for audio
# generation to work correctly):
# OMNI_SYSTEM_PROMPT="You are Qwen, a BFSI compliance assistant..."

# ─── API Server ────────────────────────────────────────────────────────────────
# OMNI_API_HOST=0.0.0.0
# OMNI_API_PORT=8000
# OMNI_API_RELOAD=false      # set true for hot-reload in development
